  }
}}%%
sequenceDiagram
    autonumber
    actor V as 👤 Visiteur
    participant FE as 🌐 Next.js Frontend
    participant BE as 🛠️ NestJS Backend
    participant SA as 🔐 Supabase Auth
    participant DB as 🗄️ PostgreSQL

    rect rgb(255, 255, 255)
        Note over V,DB: 🔑 Login
        V->>FE: Saisit email + mot de passe
        FE->>SA: signInWithPassword(email, password)
        alt Succès
            SA-->>FE: { access_token (JWT HS256), refresh_token }
            FE->>BE: GET /auth/me (Authorization: Bearer <token>)
            BE->>BE: JwtAuthGuard — vérifie signature JWT
            BE->>DB: SELECT profile WHERE id = sub AND is_active = true
            DB-->>BE: profil utilisateur
            BE-->>FE: { id, full_name, role, is_active }
            FE-->>V: Redirige vers /dashboard
        else Compte désactivé
            BE-->>FE: 401 "Compte désactivé. Contactez votre administrateur."
        else Token expiré
            BE-->>FE: 401 "Session expirée. Veuillez vous reconnecter."
        else Mot de passe incorrect
            SA-->>FE: 400 "Invalid credentials"
            FE-->>V: Message d'erreur affiché
        end
    end