graph TD
    C(["💼 Commercial"])
    A(["🛡️ Administrateur"])

    UC1["Lister les contacts"]
    UC2["Rechercher / filtrer les contacts"]
    UC3["Voir le détail d'un contact"]
    UC4["Créer un contact"]
    UC5["Modifier un contact"]
    UC6["Supprimer un contact"]
    UC7["Voir la timeline d'interactions"]
    UC8["Ajouter une interaction (note, appel, email…)"]
    UC9["Voir les leads associés"]
    UC10["Être authentifié"]

    C --> UC1
    C --> UC3
    C --> UC4
    C --> UC5
    C --> UC7
    C --> UC8
    C --> UC9

    A --> UC1
    A --> UC3
    A --> UC6

    UC1 -.->|include| UC10
    UC2 -.->|include| UC10
    UC3 -.->|include| UC10
    UC4 -.->|include| UC10
    UC5 -.->|include| UC10
    UC6 -.->|include| UC10

    UC1 -.->|extend| UC2
